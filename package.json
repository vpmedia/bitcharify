{
  "name": "@vpmedia/bitcharify",
  "version": "1.26.0",
  "description": "@vpmedia/bitcharify is a bitmap font generator",
  "author": "Andras Csizmadia <andras@vpmedia.hu> (www.vpmedia.hu)",
  "license": "MIT",
  "homepage": "https://github.com/vpmedia/bitcharify#readme",
  "bugs": {
    "url": "https://github.com/vpmedia/bitcharify/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpmedia/bitcharify.git"
  },
  "keywords": [
    "bitcharify",
    "bitmap",
    "font",
    "generator",
    "factory",
    "phaser",
    "phaser2",
    "phaser3"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c && tsc -p tsconfig.json --emitDeclarationOnly",
    "check": "pnpm lint && pnpm test && pnpm typecheck",
    "format": "oxfmt --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,css}\"",
    "lint": "oxlint src",
    "test": "vitest --coverage",
    "typecheck": "tsc"
  }
}
